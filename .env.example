# Safe local defaults only. Copy to .env.local and do not commit that file.
APP_ENV=local
PORT=8080
MYSQL_DSN=bp_companion:bp_companion_local@tcp(127.0.0.1:3306)/bp_companion?parseTime=true&charset=utf8mb4&loc=UTC
MYSQL_ROOT_PASSWORD=local-root-only
MYSQL_DATABASE=bp_companion
MYSQL_USER=bp_companion
MYSQL_PASSWORD=bp_companion_local
MIGRATION_STATEMENT_TIMEOUT=5m
DATA_ENCRYPTION_KEY_B64=
DATA_ENCRYPTION_KEY_VERSION=v1
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TEMPLATE_ID=
CLOUDBASE_ENV_ID=
CLOUDBASE_SERVICE_NAME=
NOTIFIER_MODE=fake
MEDIA_PROVIDER_MODE=fake
OCR_REGION=
ASR_REGION=
LOG_LEVEL=info
